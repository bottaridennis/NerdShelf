rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: libraryItems
    // Document ID: {itemId}
    // Fields:
    //   - userId: string (required, immutable) - Owner's UID
    //   - title: string (required, min 1, max 200)
    //   - author: string (optional, max 200)
    //   - category: string (required, enum: ['book', 'manga', 'gdr'])
    //   - status: string (required, enum: ['unread', 'reading', 'read'])
    //   - genre: string (optional)
    //   - price: number (optional)
    //   - isbn: string (optional)
    //   - totalVolumes: string (optional)
    //   - system: string (optional)
    //   - totalPages: number (optional)
    //   - pagesRead: number (optional)
    //   - coverUrl: string (optional)
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidLibraryItem(data) {
      return data.keys().hasAll(['userId', 'title', 'category', 'status', 'createdAt']) &&
             data.keys().hasOnly(['userId', 'title', 'author', 'category', 'status', 'genre', 'price', 'isbn', 'totalVolumes', 'system', 'totalPages', 'pagesRead', 'coverUrl', 'createdAt']) &&
             data.userId is string &&
             data.title is string && data.title.size() >= 1 && data.title.size() <= 200 &&
             (!('author' in data) || (data.author is string && data.author.size() <= 200)) &&
             data.category in ['book', 'manga', 'gdr'] &&
             data.status in ['unread', 'reading', 'read'] &&
             (!('genre' in data) || data.genre is string) &&
             (!('price' in data) || (data.price is number && data.price >= 0)) &&
             (!('isbn' in data) || data.isbn is string) &&
             (!('totalVolumes' in data) || data.totalVolumes is string) &&
             (!('system' in data) || data.system is string) &&
             (!('totalPages' in data) || (data.totalPages is number && data.totalPages >= 0)) &&
             (!('pagesRead' in data) || (data.pagesRead is number && data.pagesRead >= 0)) &&
             (!('coverUrl' in data) || data.coverUrl is string) &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /libraryItems/{itemId} {
      // Users can only read their own items
      allow read: if isOwner(resource.data.userId);
      
      // Users can create items for themselves
      allow create: if isOwner(request.resource.data.userId) && 
                      isValidLibraryItem(request.resource.data);
      
      // Users can update their own items, but userId and createdAt are immutable
      allow update: if isOwner(resource.data.userId) && 
                      isOwner(request.resource.data.userId) &&
                      isValidLibraryItem(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      
      // Users can delete their own items
      allow delete: if isOwner(resource.data.userId);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
